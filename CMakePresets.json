{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 28,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "vendored_env",
      "binaryDir": "${sourceDir}/build",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_PREFIX_PATH": "${sourceDir}/env",
        "CMAKE_BUILD_TYPE": "Debug"
      }
    }
  ]
}
